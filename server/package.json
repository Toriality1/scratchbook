{
  "name": "scratchbook-server",
  "type": "module",
  "version": "0.3.0",
  "description": "ScratchBook's backend files",
  "main": "server.js",
  "scripts": {
    "server": "node --env-file=.env --watch --experimental-strip-types src/server.ts",
    "build": "tsc",
    "client": "npm run dev --prefix ../client",
    "dev": "concurrently -p \"{time} {name}\" -t \"[dd] [HH:mm:ss]\" -n \"SERVER,CLIENT\" -c \"bgBlue,inverse\" \"cross-env NODE_ENV=development nodemon server\" \"npm run client\""
  },
  "author": "Pedro Crelier",
  "license": "ISC",
  "dependencies": {
    "@hapi/joi": "^17.1.1",
    "bcrypt": "^6.0.0",
    "chalk": "^5.3.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "envalid": "^8.1.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.3.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
